+    def enable_lora(self, r, alpha, dropout, targets):
+        """Attach LoRA parameters to the targeted projections.
+
+        targets: iterable subset of {"q", "k", "v", "out"}.
+        Standard LoRA init (Hu et al. 2021): A ~ kaiming_uniform, B = 0, so the
+        initial delta is zero and the module reproduces the pretrained weights.
+        """
+        assert r > 0
+        valid = {"q", "k", "v", "out"}
+        targets = set(targets)
+        assert targets <= valid, f"invalid LoRA targets: {targets - valid}"
+
+        proj_in = {
+            "q": (self.embed_dim, self.embed_dim),
+            "k": (self.kdim, self.embed_dim),
+            "v": (self.vdim, self.embed_dim),
+            "out": (self.embed_dim, self.embed_dim),
