 @dataclass
 class ECGTransformerClassificationConfig(ECGTransformerFinetuningConfig):
     num_labels: int = field(
         default=MISSING, metadata={"help": "number of labels to be classified"}
     )
 
+    # LoRA (parameter-efficient fine-tuning). lora_r=0 disables LoRA entirely,
+    # in which case the model behaves exactly as upstream (full / frozen FT
+    # controlled by feature_grad_mult and freeze_finetune_updates).
+    lora_r: int = field(
+        default=0, metadata={"help": "LoRA rank; 0 disables LoRA"}
+    )
+    lora_alpha: int = field(
+        default=16, metadata={"help": "LoRA alpha (scaling = alpha / r)"}
+    )
+    lora_dropout: float = field(
+        default=0.0, metadata={"help": "dropout on the LoRA input path"}
+    )
+    lora_targets: str = field(
+        default="q,v",
+        metadata={"help": "comma-separated attention projections to adapt: q,k,v,out"},
+    )
+    lora_layers: str = field(
+        default="all",
+        metadata={
+            "help": "which encoder layers get LoRA: 'all', 'lastN' (e.g. last4), "
+            "'firstN', or an explicit comma-separated list of 0-based indices"
+        },
+    )
+
+
+def _resolve_lora_layers(spec, n_layers):
+    spec = spec.strip().lower()
+    if spec == "all":
+        return set(range(n_layers))
+    if spec.startswith("last"):
+        k = int(spec[len("last"):])
+        return set(range(max(0, n_layers - k), n_layers))
+    if spec.startswith("first"):
+        k = int(spec[len("first"):])
+        return set(range(min(k, n_layers)))
+    return set(int(x) for x in spec.split(",") if x.strip() != "")
+
+
+def apply_lora(model, cfg):
+    """Inject LoRA into the targeted encoder layers and freeze the backbone.
+
+    Only LoRA parameters and the classification head remain trainable.
+    """
+    targets = [t.strip() for t in cfg.lora_targets.split(",") if t.strip()]
+    layers = model.encoder.encoder.layers
+    layer_idxs = _resolve_lora_layers(cfg.lora_layers, len(layers))
+
+    for i, layer in enumerate(layers):
+        if i in layer_idxs:
+            layer.self_attn.enable_lora(
+                cfg.lora_r, cfg.lora_alpha, cfg.lora_dropout, targets
+            )
+
+    trainable = 0
+    total = 0
+    for name, p in model.named_parameters():
+        total += p.numel()
+        if ("lora_" in name) or name.startswith("proj."):
+            p.requires_grad = True
+            trainable += p.numel()
+        else:
+            p.requires_grad = False
+
+    logger.info(
+        f"LoRA enabled: r={cfg.lora_r}, alpha={cfg.lora_alpha}, "
+        f"targets={targets}, layers={sorted(layer_idxs)} | "
+        f"trainable {trainable:,} / {total:,} params "
+        f"({100.0 * trainable / total:.3f}%)"
+    )
+
 @register_model("ecg_transformer_classifier", dataclass=ECGTransformerClassificationConfig)
