+            self.register_parameter(f"lora_A_{name}", lora_A)
+            self.register_parameter(f"lora_B_{name}", lora_B)
+
+        self.lora_enabled = True
+        self.lora_targets = targets
+        self.lora_scaling = alpha / r
+        self.lora_drop = nn.Dropout(p=dropout) if dropout > 0 else nn.Identity()
