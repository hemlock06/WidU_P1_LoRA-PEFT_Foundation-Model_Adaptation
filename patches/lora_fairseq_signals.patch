+    def _project(self, x, weight, bias, name):
+        out = F.linear(x, weight, bias)
+        if name in self.lora_targets:
+            lora_A = getattr(self, f"lora_A_{name}")
+            lora_B = getattr(self, f"lora_B_{name}")
+            out = out + self.lora_scaling * F.linear(
+                F.linear(self.lora_drop(x), lora_A), lora_B
+            )
+        return out
+
+    def _forward_lora(
+        self, query, key, value, key_padding_mask, need_weights, attn_mask
+    ):
+        """Explicit-projection self-attention with LoRA deltas.
+
+        Reproduces F.multi_head_attention_forward (scaled dot-product, separate
+        q/k/v projections, head reshape, key-padding masking) so that with a
+        zero LoRA delta and dropout off the output matches the fused path.
+        """
+        tgt_len, bsz, embed_dim = query.size()
+        src_len = key.size(0)
+        n_heads = self.n_heads
+        d_head = self.d_heads
+        scaling = d_head ** -0.5
+
+        q = self._project(query, self.q_proj.weight, self.q_proj.bias, "q")
+        k = self._project(key, self.k_proj.weight, self.k_proj.bias, "k")
+        v = self._project(value, self.v_proj.weight, self.v_proj.bias, "v")
+
+        q = q * scaling
+
+        q = q.contiguous().view(tgt_len, bsz * n_heads, d_head).transpose(0, 1)
+        k = k.contiguous().view(src_len, bsz * n_heads, d_head).transpose(0, 1)
+        v = v.contiguous().view(src_len, bsz * n_heads, d_head).transpose(0, 1)
+
+        attn_weights = torch.bmm(q, k.transpose(1, 2))  # (bsz*n_heads, tgt, src)
+
+        if attn_mask is not None:
+            attn_weights = attn_weights + attn_mask
+
+        if key_padding_mask is not None and key_padding_mask.any():
+            attn_weights = attn_weights.view(bsz, n_heads, tgt_len, src_len)
+            attn_weights = attn_weights.masked_fill(
+                key_padding_mask.unsqueeze(1).unsqueeze(2).to(torch.bool),
+                float("-inf"),
+            )
+            attn_weights = attn_weights.view(bsz * n_heads, tgt_len, src_len)
+
+        attn_weights_float = F.softmax(attn_weights.float(), dim=-1).type_as(attn_weights)
+
+        training = self.training or self.dropout.apply_during_inference
+        attn_probs = F.dropout(attn_weights_float, p=self.dropout.p, training=training)
+
+        attn = torch.bmm(attn_probs, v)  # (bsz*n_heads, tgt, d_head)
+        attn = attn.transpose(0, 1).contiguous().view(tgt_len, bsz, embed_dim)
+        attn = self._project(attn, self.out_proj.weight, self.out_proj.bias, "out")
+
+        if need_weights:
+            attn_weights_out = attn_weights_float.view(
+                bsz, n_heads, tgt_len, src_len
+            ).mean(dim=1)
+            return attn, attn_weights_out
+        return attn, None
